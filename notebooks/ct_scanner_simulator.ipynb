    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"image_dropdown = widgets.Dropdown(options=list(available_images.keys()), value=\\\"Shepp_logan\\\", description='Obraz:')\\n\",\n",
    "    \"preview_output = widgets.Output()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def update_image_preview(change):\\n\",\n",
    "    \"    global current_image_name, current_image_array\\n\",\n",
    "    \"    with preview_output:\\n\",\n",
    "    \"        clear_output(wait=True)\\n\",\n",
    "    \"        current_image_name = change.new\\n\",\n",
    "    \"        img_path = available_images[current_image_name]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            img_array = plt.imread(img_path)\\n\",\n",
    "    \"            if len(img_array.shape) == 3:\\n\",\n",
    "    \"                img_array = np.mean(img_array, axis=2)\\n\",\n",
    "    \"            current_image_array = img_array\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if 'render_background' in globals():\\n\",\n",
    "    \"                render_background()\\n\",\n",
    "    \"                update_geometry()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            plt.figure(figsize=(4, 4))\\n\",\n",
    "    \"            plt.imshow(current_image_array, cmap='gray')\\n\",\n",
    "    \"            plt.title(f\\\"Wybrano: {current_image_name}\\\")\\n\",\n",
    "    \"            plt.axis('off')\\n\",\n",
    "    \"            plt.show()\\n\",\n",
    "    \"        except FileNotFoundError:\\n\",\n",
    "    \"            print(f\\\"Błąd: Nie znaleziono pliku {img_path}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"image_dropdown.observe(update_image_preview, names='value')\\n\",\n",
    "    \"display(image_dropdown, preview_output)\\n\",\n",
    "    \"update_image_preview({'new': image_dropdown.value})\"\n",
    "   ],\n",
