    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"angle_slider     = widgets.IntSlider(min=0,  max=360, step=5,  value=0,   description='Kąt (st):')\\n\",\n",
    "    \"detectors_slider = widgets.IntSlider(min=10, max=720, step=10, value=180, description='Detektory:')\\n\",\n",
    "    \"span_slider      = widgets.IntSlider(min=45, max=270, step=45, value=180, description='Rozpiętość:')\\n\",\n",
    "    \"title_label      = widgets.Label(value='')\\n\",\n",
    "    \"canvas           = widgets.Image(format='png', layout=widgets.Layout(width=f'{PLOT_PX}px', height=f'{PLOT_PX}px'))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _fig_to_pil(fig, transparent=False) -> PILImage:\\n\",\n",
    "    \"    buf = io.BytesIO()\\n\",\n",
    "    \"    fig.savefig(buf, format='png', dpi=DPI, transparent=transparent, bbox_inches=None)\\n\",\n",
    "    \"    plt.close(fig)\\n\",\n",
    "    \"    buf.seek(0)\\n\",\n",
    "    \"    return PILImage.open(buf).convert('RGBA')\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _pil_to_bytes(img: PILImage) -> bytes:\\n\",\n",
    "    \"    buf = io.BytesIO()\\n\",\n",
    "    \"    img.save(buf, format='png')\\n\",\n",
    "    \"    buf.seek(0)\\n\",\n",
    "    \"    return buf.read()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def render_background():\\n\",\n",
    "    \"    global _bg_pil\\n\",\n",
    "    \"    if current_image_array is None:\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"    H, W = current_image_array.shape\\n\",\n",
    "    \"\\n\",\n",
    "    \"    fig = plt.figure(figsize=(FIG_IN, FIG_IN), dpi=DPI)\\n\",\n",
    "    \"    ax  = fig.add_axes([0, 0, 1, 1])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    ax.imshow(current_image_array, cmap='gray', extent=[0, W, H, 0], aspect='equal')\\n\",\n",
    "    \"    ax.legend(\\n\",\n",
    "    \"        handles=[\\n\",\n",
    "    \"            Line2D([0],[0], marker='o', color='w', markerfacecolor='r', markersize=8, label='Emiter'),\\n\",\n",
    "    \"            Line2D([0],[0], marker='o', color='w', markerfacecolor='b', markersize=4, label='Detektory'),\\n\",\n",
    "    \"        ],\\n\",\n",
    "    \"        loc='upper right', framealpha=0.6, facecolor='#111', labelcolor='white', fontsize=9\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    ax.set_xlim(0, W); ax.set_ylim(H, 0); ax.axis('off')\\n\",\n",
    "    \"    _bg_pil = _fig_to_pil(fig, transparent=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def update_geometry(change=None):\\n\",\n",
    "    \"    if current_image_array is None or _bg_pil is None:\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"    H, W = current_image_array.shape\\n\",\n",
    "    \"\\n\",\n",
    "    \"    angle     = angle_slider.value\\n\",\n",
    "    \"    detectors = detectors_slider.value\\n\",\n",
    "    \"    span      = span_slider.value\\n\",\n",
    "    \"\\n\",\n",
    "    \"    xe, ye        = emitter_pos(current_image_array, angle)\\n\",\n",
    "    \"    from src.detectors import detectors_pos\\n\",\n",
    "    \"    detectors_pos = detectors_pos(current_image_array, angle, detectors, span)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    fig = plt.figure(figsize=(FIG_IN, FIG_IN), dpi=DPI)\\n\",\n",
    "    \"    ax  = fig.add_axes([0, 0, 1, 1])\\n\",\n",
    "    \"    fig.patch.set_alpha(0)\\n\",\n",
    "    \"    ax.patch.set_alpha(0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if detectors_pos:\\n\",\n",
    "    \"        xd, yd = zip(*detectors_pos)\\n\",\n",
    "    \"        ax.add_collection(LineCollection(\\n\",\n",
    "    \"            [[(xe, ye), (xi, yi)] for xi, yi in detectors_pos],\\n\",\n",
    "    \"            colors='r', alpha=0.15, linewidths=0.8\\n\",\n",
    "    \"        ))\\n\",\n",
    "    \"        ax.plot(xd, yd, 'bo', markersize=4, markeredgewidth=0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    ax.plot([xe], [ye], 'ro', markersize=8, markeredgewidth=0)\\n\",\n",
    "    \"    ax.set_xlim(0, W); ax.set_ylim(H, 0); ax.axis('off')\\n\",\n",
    "    \"\\n\",\n",
    "    \"    overlay_pil = _fig_to_pil(fig, transparent=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    composite = _bg_pil.copy()\\n\",\n",
    "    \"    composite.paste(overlay_pil, (0, 0), mask=overlay_pil)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    title_label.value = f'Kąt: {angle}°  |  detektory: {detectors}  |  rozpiętość: {span}°'\\n\",\n",
    "    \"    canvas.value = _pil_to_bytes(composite)\\n\",\n",
    "    \"\\n\",\n",
    "    \"angle_slider.observe(update_geometry, names='value')\\n\",\n",
    "    \"detectors_slider.observe(update_geometry, names='value')\\n\",\n",
    "    \"span_slider.observe(update_geometry, names='value')\\n\",\n",
    "    \"\\n\",\n",
    "    \"display(widgets.VBox([angle_slider, detectors_slider, span_slider, title_label, canvas]))\\n\",\n",
    "    \"\\n\",\n",
    "    \"if current_image_array is not None:\\n\",\n",
    "    \"    render_background()\\n\",\n",
    "    \"    update_geometry()\"\n",
    "   ],\n",
