    "     \"end_time\": \"2026-04-18T11:49:37.574406100Z\",\n",
    "     \"start_time\": \"2026-04-18T11:49:37.539886800Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"scans_input = widgets.IntSlider(min=90, max=720, step=90, value=180, description='L. skanów:')\\n\",\n",
    "    \"filter_checkbox = widgets.Checkbox(value=False, description='Użyj filtru splotowego')\\n\",\n",
    "    \"run_button = widgets.Button(description=\\\"Uruchom Skanowanie\\\", button_style='info')\\n\",\n",
    "    \"\\n\",\n",
    "    \"history_slider = widgets.IntSlider(min=1, max=180, step=1, value=180, description='Iteracja:', layout=widgets.Layout(width='600px'))\\n\",\n",
    "    \"player_ui = widgets.VBox([history_slider])\\n\",\n",
    "    \"player_ui.layout.display = 'none'\\n\",\n",
    "    \"\\n\",\n",
    "    \"results_output = widgets.Output()\\n\",\n",
    "    \"progress_bar = widgets.IntProgress(value=0, min=0, max=100, description='Postęp:', bar_style='info')\\n\",\n",
    "    \"\\n\",\n",
    "    \"def execute_scan(b):\\n\",\n",
    "    \"    global full_sinogram, reconstruction_history, latest_reconstructed_image\\n\",\n",
    "    \"\\n\",\n",
    "    \"    with results_output:\\n\",\n",
    "    \"        clear_output(wait=True)\\n\",\n",
    "    \"        if current_image_array is None:\\n\",\n",
    "    \"            print(\\\"Wybierz obraz w drugiej komórce!\\\")\\n\",\n",
    "    \"            return\\n\",\n",
    "    \"\\n\",\n",
    "    \"        detectors = detectors_slider.value\\n\",\n",
    "    \"        span = span_slider.value\\n\",\n",
    "    \"        scans = scans_input.value\\n\",\n",
    "    \"        use_filter = filter_checkbox.value\\n\",\n",
    "    \"\\n\",\n",
    "    \"        player_ui.layout.display = 'none'\\n\",\n",
    "    \"        progress_bar.value = 10\\n\",\n",
    "    \"        display(progress_bar)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        progress_bar.description = 'Sinogram...'\\n\",\n",
    "    \"        full_sinogram = get_sinogram(current_image_array, detectors, scans, span)\\n\",\n",
    "    \"        progress_bar.value = 40\\n\",\n",
    "    \"\\n\",\n",
    "    \"        progress_bar.description = 'Filtrowanie...'\\n\",\n",
    "    \"        if use_filter:\\n\",\n",
    "    \"            full_sinogram = apply_filter(full_sinogram)\\n\",\n",
    "    \"        progress_bar.value = 50\\n\",\n",
    "    \"\\n\",\n",
    "    \"        progress_bar.description = 'Rekonstrukcja...'\\n\",\n",
    "    \"        reconstruction_history = inverse_radon(full_sinogram, current_image_array.shape, detectors, scans, span, return_history=True)\\n\",\n",
    "    \"        progress_bar.value = 90\\n\",\n",
    "    \"\\n\",\n",
    "    \"        latest_reconstructed_image = reconstruction_history[-1]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        progress_bar.value = 100\\n\",\n",
    "    \"        progress_bar.description = 'Gotowe!'\\n\",\n",
    "    \"        history_slider.max = scans\\n\",\n",
    "    \"        history_slider.value = scans\\n\",\n",
    "    \"        player_ui.layout.display = 'block'\\n\",\n",
    "    \"\\n\",\n",
    "    \"        setup_player()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def setup_player():\\n\",\n",
    "    \"    clear_output(wait=True)\\n\",\n",
    "    \"    image_widget = widgets.Image(format='png', width=900, height=350)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.ioff()\\n\",\n",
    "    \"    fig, axes = plt.subplots(1, 3, figsize=(15, 5))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    axes[0].imshow(current_image_array, cmap='gray')\\n\",\n",
    "    \"    axes[0].set_title(\\\"Obraz wejściowy\\\")\\n\",\n",
    "    \"    axes[0].axis('off')\\n\",\n",
    "    \"\\n\",\n",
    "    \"    im_sino = axes[1].imshow(np.zeros_like(full_sinogram), cmap='gray', aspect='auto', vmin=0, vmax=np.max(full_sinogram))\\n\",\n",
    "    \"    axes[1].set_title(\\\"Sinogram (Tworzenie)\\\")\\n\",\n",
    "    \"    axes[1].axis('off')\\n\",\n",
    "    \"\\n\",\n",
    "    \"    im_recon = axes[2].imshow(np.zeros_like(current_image_array), cmap='gray', vmin=0, vmax=255)\\n\",\n",
    "    \"    axes[2].set_title(\\\"Rekonstrukcja\\\")\\n\",\n",
    "    \"    axes[2].axis('off')\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def update_frame(change):\\n\",\n",
    "    \"        step = history_slider.value\\n\",\n",
    "    \"\\n\",\n",
    "    \"        partial_sinogram = np.zeros_like(full_sinogram)\\n\",\n",
    "    \"        partial_sinogram[:step, :] = full_sinogram[:step, :]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        im_sino.set_data(partial_sinogram)\\n\",\n",
    "    \"        im_recon.set_data(reconstruction_history[step - 1])\\n\",\n",
    "    \"\\n\",\n",
    "    \"        current_rmse = calculate_rmse(current_image_array, reconstruction_history[step - 1])\\n\",\n",
    "    \"        fig.suptitle(f\\\"Krok: {step}/{history_slider.max} | Ostatnie RMSE: {current_rmse:.4f}\\\", fontsize=14)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        buf = io.BytesIO()\\n\",\n",
    "    \"        fig.savefig(buf, format='png', bbox_inches='tight')\\n\",\n",
    "    \"        buf.seek(0)\\n\",\n",
    "    \"        image_widget.value = buf.read()\\n\",\n",
    "    \"        buf.close()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    history_slider.observe(update_frame, names='value')\\n\",\n",
    "    \"    display(widgets.VBox([player_ui, image_widget]))\\n\",\n",
    "    \"    update_frame(None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"run_button.on_click(execute_scan)\\n\",\n",
    "    \"display(widgets.VBox([scans_input, filter_checkbox, run_button, results_output]))\"\n",
