    "    \"    \\\"Kwadraty2\\\": \\\"../data/input/Kwadraty2.jpg\\\",\\n\",\n",
    "    \"    \\\"Paski2\\\": \\\"../data/input/Paski2.jpg\\\",\\n\",\n",
    "    \"    \\\"SADDLE_PE\\\": \\\"../data/input/SADDLE_PE.jpg\\\",\\n\",\n",
    "    \"    \\\"SADDLE_PE-large\\\": \\\"../data/input/SADDLE_PE-large.jpg\\\",\\n\",\n",
    "    \"    \\\"Shepp_logan\\\": \\\"../data/input/Shepp_logan.jpg\\\"\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
